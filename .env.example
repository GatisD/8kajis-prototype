# ============================================================
# 8kajis.lv — Environment Variables
# Kopē šo failu uz .env un aizpildi ar reālajām vērtībām
# NEKAD nepievieno .env pie git!
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (public key — drīkst būt publisks)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_KEY

# Google reCAPTCHA v3 (public key)
VITE_RECAPTCHA_SITE_KEY=6LeYourRecaptchaSiteKey

# Analytics — atkomentē kad ir reālie ID
# VITE_GA4_ID=G-XXXXXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX

# ============================================================
# Šīs mainīgās tiek iestatītas Vercel Dashboard → Settings → Environment Variables
# UN Supabase Dashboard → Edge Functions → Secrets
# NEKAD neliec iekšā koda bāzē!
# ============================================================
# RESEND_API_KEY=re_YOUR_RESEND_KEY
# STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key (TIKAI serverī!)
